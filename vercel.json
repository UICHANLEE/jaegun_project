{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/jaegunadmin/:sessionId",
      "destination": "/jaegunadmin.html?archiveSession=:sessionId"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
